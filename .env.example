# Database
POSTGRES_HOST=localhost # для локального postgres
# POSTGRES_HOST=postgres # имя сервиса postgres в docker compose
POSTGRES_PORT=5432
POSTGRES_USER=devuser
POSTGRES_PASSWORD=devpass
POSTGRES_DB=skillswap

# App
NODE_ENV=development
PORT=3000

# Auth
HASH_SALT=10

# JWT
JWT_ACCESS_SECRET=<REPLACEME>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=<REPLACEME>
JWT_REFRESH_EXPIRY=7d
